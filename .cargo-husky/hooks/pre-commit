#!/usr/bin/env bash
# cargo-husky entry point — delegates to canonical .konjo/hooks/pre-commit
# cargo-husky installs this file into .git/hooks/pre-commit automatically
# when `cargo build` or `cargo test` runs.
#
# Do not edit this file. Edit .konjo/hooks/pre-commit instead.
set -euo pipefail
REPO_ROOT="$(git rev-parse --show-toplevel)"
exec "$REPO_ROOT/.konjo/hooks/pre-commit" "$@"
