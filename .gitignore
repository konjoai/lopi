/target
**/*.rs.bk
*.pdb
Cargo.lock.bak
.lopi/
*.db
*.db-journal
*.db-wal
*.db-shm
.DS_Store
.env
.env.local
lopi.toml
mutants.out/

# E2E screenshots are delivered separately, not committed (binary blobs)
artifacts/screenshots/

# Locally-built plugin binary — see scripts/build-plugin-bin.sh. Not
# committed: platform-specific, and Track B (MCPB) is where prebuilt
# cross-platform binaries eventually come from.
/plugin/bin/

# Swift Package Manager build output (packages/LopiStacksKit) and
# packaged MCP bundles — build artifacts, not source.
.build/
.swiftpm/
*.mcpb
